# Apex Configuration
# Copy to .env and fill in values

APEX_DEBUG=true
APEX_DB_PATH=apex_dev.duckdb
APEX_DATABASE_URL=duckdb:///./apex.duckdb
# APEX_POSTGRES_URL=postgresql://user:pass@localhost:5432/apex
APEX_REDIS_URL=redis://localhost:6379/0
APEX_KAMINO_API_URL=http://localhost:8000
APEX_DATA_REFRESH_INTERVAL_MINUTES=15
APEX_ALERT_EVALUATION_INTERVAL_MINUTES=5

# Anthropic (for Paperclip agents)
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------
# External Data Connectors
# Set credentials below to enable live data from external sources.
# When credentials are missing, Apex uses built-in seed data.
# ---------------------------------------------------------------

# Google Analytics 4
# GA4_PROPERTY_ID=123456789
# GA4_CREDENTIALS_JSON=/path/to/service-account.json

# SEMrush
# SEMRUSH_API_KEY=your-semrush-api-key

# Google Ads
# GOOGLE_ADS_DEVELOPER_TOKEN=your-dev-token
# GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_ADS_CLIENT_SECRET=your-client-secret
# GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# GOOGLE_ADS_CUSTOMER_ID=1234567890

# Meta Ads (Facebook / Instagram)
# META_ADS_ACCESS_TOKEN=your-long-lived-access-token
# META_ADS_ACCOUNT_ID=act_123456789
